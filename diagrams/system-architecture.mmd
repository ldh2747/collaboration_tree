flowchart TB
    subgraph CLIENT["🖥️ Client (Browser)"]
        direction TB
        RC["React + Vite"]
        RF["@xyflow/react\n(MindMapCanvas)"]
        CN["CustomNode\n(노드 컴포넌트)"]
        AI["AISidebar\n(AI 확장/분석)"]
        YP["YjsMindmapProvider\n(Yjs Y.Doc)"]
        ZS["Zustand\n(AuthStore)"]
        RC --> RF & AI & ZS
        RF --> CN
        RF --> YP
    end

    subgraph SERVER["⚙️ Server (Node.js / Express)"]
        direction TB
        subgraph REST["REST API"]
            R1["/api/auth"]
            R2["/api/mindmaps"]
            R3["/api/ai"]
        end
        subgraph SOCK["Socket.io"]
            S1["join_room"]
            S2["yjs_join / yjs_update"]
            S3["cursor_move / reaction"]
        end
        YM["YjsManager\n(In-Memory Y.Doc Rooms)"]
