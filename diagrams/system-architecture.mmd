    OPENAI["☁️ OpenAI API\nGPT-4o-mini\n(SSE Streaming)"]

    YP -- "yjs_update\n(WebSocket)" --> S2
    CN -- "HTTP (axios)" --> REST
    AI -- "HTTP (axios)" --> R3
    ZS -- "HTTP (axios)" --> R1

    YM --> DB
    REST --> DB
    R3 --> OPENAI

